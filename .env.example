# SMTP Konfiguration (Hostpoint / Infomaniak / etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=info@example.com
SMTP_PASSWORD=replace_with_strong_password
# Optional: falls Zertifikat-Name vom Host abweicht
SMTP_TLS_SERVERNAME=smtp.example.com

# Empfaenger der Kontaktanfragen
EMAIL_TO=info@masesites.ch

# Server Port
PORT=3000

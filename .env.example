# ===== ABJ Shop – Umgebungsvariablen =====
# Kopiere diese Datei zu ".env" und passe die Werte an.
# .env NIEMALS committen oder weitergeben!

# Server
NODE_ENV=development
PORT=3000

# Geheimnisse (lange, zufällige Zeichenketten verwenden!)
# z.B. mit: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=bitte-aendern-lange-zufaellige-zeichenkette
CSRF_SECRET=bitte-aendern-andere-lange-zufaellige-zeichenkette

# Seitenweite Zugangs-Sperre ("Coming Soon")
# Start-Passwort beim ersten Hochfahren. Später im Admin-Dashboard änderbar.
GATE_PASSWORD=geheim-zugang-2026

# Cookie-Sicherheit: in Produktion (NODE_ENV=production) immer true (nur über HTTPS)
COOKIE_SECURE=false

# ===== Zahlungen (später) – aktuell ungenutzt =====
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=

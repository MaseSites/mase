assets/img/demos$*.png

# Server-Daten: Datenbank, Schluessel, Startpasswort (niemals committen)
# Node-Fassung:
server/daten/
# PHP-Fassung: Inhalt ignorieren, aber die Schutz-.htaccess behalten
daten/*

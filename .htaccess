# masesites – Apache-Konfiguration für Plesk & klassisches Webhosting.
# Die statischen Seiten liefert Apache direkt aus; /api/... geht an api.php.
# Es wird KEIN Node.js benötigt – das Backend ist reines PHP (api.php).

# ---------- Node.js/Passenger abschalten ----------
# Läuft die Seite nicht (überall Fehler 500) und ist in Plesk unter
# "Node.js" für diese Domain versehentlich noch eine App aktiv, dann fängt
# Phusion Passenger alle Anfragen ab und scheitert, weil kein Node da ist.
# Sauberste Lösung: in Plesk unter Websites & Domains → Node.js auf
# "Node.js deaktivieren" klicken. Klappt das nicht, die folgende Zeile
# (das # davor entfernen) erzwingt dasselbe direkt hier:
#<IfModule mod_passenger.c>
#  PassengerEnabled off
#</IfModule>

# ---------- API-Routing: /api/... an die PHP-API ----------
<IfModule mod_rewrite.c>
  RewriteEngine On
  # Wird die Seite in einem Unterordner betrieben, hier den Pfad setzen, z. B.
  # RewriteBase /
  RewriteRule ^api/ api.php [QSA,L]
</IfModule>

# ---------- Schutz sensibler Dateien ----------
# Node-Server-Ordner (falls vorhanden) nie ausliefern
RedirectMatch 404 ^/server(/|$)
# Git-Metadaten und versteckte Konfigdateien sperren
RedirectMatch 404 (^|/)\.(git|env)(/|$)
# Datenbank-, Schlüssel- und Konfig-Dateien in jedem Ordner blocken
<IfModule mod_authz_core.c>
  <FilesMatch "\.(key|db|db-wal|db-shm|sqlite|sqlite3)$">
    Require all denied
  </FilesMatch>
</IfModule>
<IfModule !mod_authz_core.c>
  <FilesMatch "\.(key|db|db-wal|db-shm|sqlite|sqlite3)$">
    Order allow,deny
    Deny from all
  </FilesMatch>
</IfModule>

# ---------- Sicherheits-Header ----------
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  <FilesMatch "\.html$">
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' https://accounts.google.com; style-src 'self' 'unsafe-inline' https://accounts.google.com https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; frame-src https:; connect-src 'self' https://accounts.google.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'"
  </FilesMatch>
</IfModule>

# ---------- Startseite ----------
DirectoryIndex index.html

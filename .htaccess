# masesites – Apache-Konfiguration für Plesk & klassisches Webhosting.
# Die statischen Seiten liefert Apache direkt aus; /api/... geht an api.php.
# Es wird KEIN Node.js benötigt – das Backend ist reines PHP (api.php).

# ---------- Node.js/Passenger abschalten ----------
# Läuft die Seite nicht (überall Fehler 500) und ist in Plesk unter
# "Node.js" für diese Domain versehentlich noch eine App aktiv, dann fängt
# Phusion Passenger alle Anfragen ab und scheitert, weil kein Node da ist.
# Sauberste Lösung: in Plesk unter Websites & Domains → Node.js auf
# "Node.js deaktivieren" klicken. Klappt das nicht, die folgende Zeile
# (das # davor entfernen) erzwingt dasselbe direkt hier:
#<IfModule mod_passenger.c>
#  PassengerEnabled off
#</IfModule>

# ---------- API-Routing: /api/... an die PHP-API ----------
<IfModule mod_rewrite.c>
  RewriteEngine On
  # Wird die Seite in einem Unterordner betrieben, hier den Pfad setzen, z. B.
  # RewriteBase /
  RewriteRule ^api/ api.php [QSA,L]

  # ---------- Alte KI-Bot-Seite: dauerhaft zur Leistungs-Welt ----------
  # Die Inhalte leben jetzt unter /leistungen#ki – alte Links und
  # Google-Treffer landen automatisch dort.
  RewriteRule ^ki-bot/?$ /leistungen#ki [R=301,L,NE]
  RewriteRule ^ki-bot\.html$ /leistungen#ki [R=301,L,NE]

  # ---------- Saubere Adressen ohne .html ----------
  # Sichtbare index-/index.html-Adressen auf die Verzeichnis-URL umleiten
  # (z. B. /index.html -> /, /admin/index.html -> /admin/).
  RewriteCond %{THE_REQUEST} \s/+((?:[^?\s]*/)?)index(?:\.html)?[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L,NE]
  # Sichtbare .html-Adressen auf die saubere Form umleiten
  # (z. B. /preise.html -> /preise).
  RewriteCond %{THE_REQUEST} \s/+([^?\s]+?)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L,NE]
  # Intern weiterhin die passende .html-Datei ausliefern, wenn vorhanden
  # (z. B. /preise -> preise.html), ohne dass die Endung sichtbar wird.
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>

# ---------- Schutz sensibler Dateien ----------
# Node-Server-Ordner (falls vorhanden) nie ausliefern
RedirectMatch 404 ^/server(/|$)
# Git-Metadaten und versteckte Konfigdateien sperren
RedirectMatch 404 (^|/)\.(git|env)(/|$)
# Datenbank-, Schlüssel- und Konfig-Dateien in jedem Ordner blocken
<IfModule mod_authz_core.c>
  <FilesMatch "\.(key|db|db-wal|db-shm|sqlite|sqlite3)$">
    Require all denied
  </FilesMatch>
</IfModule>
<IfModule !mod_authz_core.c>
  <FilesMatch "\.(key|db|db-wal|db-shm|sqlite|sqlite3)$">
    Order allow,deny
    Deny from all
  </FilesMatch>
</IfModule>

# ---------- Sicherheits-Header ----------
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  <FilesMatch "\.html$">
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' https://accounts.google.com; style-src 'self' 'unsafe-inline' https://accounts.google.com https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; frame-src https:; connect-src 'self' https://accounts.google.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'"
  </FilesMatch>
</IfModule>

# ---------- Caching: HTML immer frisch, Assets lange ----------
# HTML wird nie gecacht (jeder Deploy ist sofort in allen Browsern sichtbar,
# inklusive aktueller Sicherheits-Header). CSS/JS/Bilder duerfen lange in den
# Cache, weil ihre Version an der Adresse haengt (?v=N bzw. neue Ordnernamen
# bei Demo-Uploads).
<IfModule mod_headers.c>
  <FilesMatch "\.html?$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
  <FilesMatch "\.(css|js|mjs|svg|png|jpe?g|gif|webp|avif|ico|woff2?|ttf|otf|mp4|webm)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>

# ---------- Startseite ----------
DirectoryIndex index.html

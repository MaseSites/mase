generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id         String     @id @default(cuid())
  name       String
  category   String
  imagePath  String
  stock      Int        @default(0)
  price      Float
  cost       Float      @default(0)
  sizes      String
  movements  Movement[]
  sales      Sale[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Movement {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productName String
  category    String
  kind        String
  quantity    Int
  createdAt   DateTime @default(now())
}

model Sale {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productName String
  category    String
  kind        String   @default("sale")
  quantity    Int
  unitPrice   Float
  revenue     Float
  reason      String?
  createdAt   DateTime @default(now())
}

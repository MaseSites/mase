{
  "name": "masesites-website",
  "version": "1.0.0",
  "description": "MASESites - Professional Websites & KI-Integration",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "serve": "npx serve -l 8000",
    "build": "cd inventory && npm install && npx prisma generate && npm run build",
    "validate": "npx html-validate index.html",
    "lighthouse": "npx lighthouse https://localhost:8000 --view",
    "minify:css": "npx clean-css-cli -o styles.min.css styles.css",
    "minify:js": "npx terser script.js -o script.min.js -c -m",
    "test": "node --test tests"
  },
  "keywords": [
    "webdesign",
    "website",
    "ki-assistent",
    "switzerland",
    "seo",
    "performance"
  ],
  "author": "Matteo & Severin - MASESites",
  "license": "MIT",
  "private": true,
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "http-proxy-middleware": "^3.0.5",
    "nodemailer": "^8.0.7"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "not dead",
    "not IE 11"
  ]
}

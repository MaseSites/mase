{
  "name": "abj-shop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Sicherer E-Commerce-Shop mit privatem Admin-Dashboard",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",

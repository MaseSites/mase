<%- include('../partials/head', { adminPage: true, bodyClass: 'admin' }) %>
<%- include('../partials/admin-header') %>

<%
  const dayNames = ['So','Mo','Di','Mi','Do','Fr','Sa'];
  const W = 520, H = 160, pad = 24, n = chart.series.length;
  const bw = (W - pad * 2) / n * 0.55;
  const gap = (W - pad * 2) / n;
%>

<main class="admin-main">
  <h1>Übersicht</h1>

  <div class="stat-grid">
    <div class="stat-card"><span class="stat-num"><%= stats.revenue %></span><span class="stat-label">Umsatz (bezahlt)</span></div>
    <div class="stat-card"><span class="stat-num"><%= stats.orders %></span><span class="stat-label">Bestellungen</span></div>
    <div class="stat-card"><span class="stat-num"><%= stats.open %></span><span class="stat-label">offen</span></div>
    <div class="stat-card"><span class="stat-num"><%= stats.products %></span><span class="stat-label">Produkte (<%= stats.active %> aktiv)</span></div>
    <div class="stat-card"><span class="stat-num"><%= stats.subscribers %></span><span class="stat-label">Newsletter</span></div>
    <div class="stat-card"><span class="stat-num"><%= stats.messages %></span><span class="stat-label">neue Nachrichten</span></div>
  </div>

  <div class="admin-actions-row">
    <a class="btn btn-primary" href="/admin/produkte/neu">+ Neues Produkt</a>
    <a class="btn btn-ghost" href="/admin/produkte">Produkte verwalten</a>
    <a class="btn btn-ghost" href="/" target="_blank" rel="noopener">Shop ansehen</a>
  </div>

  <section class="admin-section">
    <h2>Bestellungen (letzte 7 Tage)</h2>
    <svg class="bar-chart" viewBox="0 0 <%= W %> <%= H %>" role="img" aria-label="Bestellungen der letzten 7 Tage">
      <% chart.series.forEach((d, i) => {
        const h = Math.round((d.orders / chart.maxOrders) * (H - pad * 2));
        const x = pad + i * gap + (gap - bw) / 2;
        const y = H - pad - h;
        const day = new Date(); day.setDate(day.getDate() - d.dayOffset);
      %>
        <rect class="bar" x="<%= x.toFixed(1) %>" y="<%= y.toFixed(1) %>" width="<%= bw.toFixed(1) %>" height="<%= Math.max(h,2) %>" rx="5"/>
        <text x="<%= (x + bw/2).toFixed(1) %>" y="<%= H - 6 %>" text-anchor="middle" font-size="11" fill="#969cb0"><%= dayNames[day.getDay()] %></text>
        <% if (d.orders > 0) { %><text x="<%= (x + bw/2).toFixed(1) %>" y="<%= (y - 5).toFixed(1) %>" text-anchor="middle" font-size="11" fill="#f3f4f8" font-weight="700"><%= d.orders %></text><% } %>
      <% }) %>
    </svg>
  </section>

  <section class="admin-section">
    <div class="admin-head-row"><h2>Letzte Bestellungen</h2><a class="btn btn-ghost btn-sm" href="/admin/bestellungen">Alle</a></div>
    <% if (recentOrders.length === 0) { %>
      <p class="muted">Noch keine Bestellungen.</p>
    <% } else { %>
      <table class="data-table">
        <thead><tr><th>Referenz</th><th>Kunde</th><th>Summe</th><th>Zahlung</th><th>Datum</th></tr></thead>
        <tbody>
          <% recentOrders.forEach((o) => { %>
            <tr>
              <td><a href="/admin/bestellungen/<%= o.reference %>"><strong><%= o.reference %></strong></a></td>
              <td><%= o.customer_name %></td>
              <td><%= price(o.total_cents) %></td>
              <td><span class="tag <%= o.payment_status === 'bezahlt' ? 'tag-ok' : '' %>"><%= o.payment_status %></span></td>
              <td class="muted"><%= o.created_at %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </section>
</main>

</body>
</html>

<%- include('../partials/head', { adminPage: true, bodyClass: 'admin' }) %>
<%- include('../partials/admin-header') %>

<%
  const dayNames = ['So','Mo','Di','Mi','Do','Fr','Sa'];
  const W = 560, H = 180, pad = 26, n = chart.series.length;
  const bw = (W - pad * 2) / n * 0.55;
  const gap = (W - pad * 2) / n;
%>

<main class="admin-main">
  <div class="admin-head-row">
    <div>
      <p class="admin-kicker">Operations</p>
      <h1>Dashboard</h1>
    </div>
    <div class="admin-actions-row compact">
      <a class="btn btn-primary" href="<%- basePath %>/admin/produkte/neu">+ Produkt</a>
      <a class="btn btn-ghost" href="<%- basePath %>/admin/lager">Lager öffnen</a>
      <a class="btn btn-ghost" href="<%- basePath %>" target="_blank" rel="noopener">Shop ansehen</a>
    </div>
  </div>

  <div class="stat-grid ops-stats">
    <div class="stat-card"><span class="stat-num"><%= stats.revenue %></span><span class="stat-label">Umsatz bezahlt</span></div>
    <div class="stat-card"><span class="stat-num"><%= stats.stockValue %></span><span class="stat-label">Bestandswert</span></div>
    <div class="stat-card"><span class="stat-num"><%= stats.availableUnits %></span><span class="stat-label">verfügbare Teile</span></div>
    <div class="stat-card"><span class="stat-num"><%= stats.lowStock %></span><span class="stat-label">niedrige Lagerzeilen</span></div>
    <div class="stat-card"><span class="stat-num"><%= stats.outOfStock %></span><span class="stat-label">ausverkauft</span></div>
    <div class="stat-card"><span class="stat-num"><%= stats.orders %></span><span class="stat-label">Bestellungen gesamt</span></div>
  </div>

  <div class="dashboard-grid">
    <section class="admin-section">
      <div class="admin-head-row"><h2>Bestellungen letzte 7 Tage</h2><span class="tag"><%= stats.open %> offen</span></div>
      <svg class="bar-chart" viewBox="0 0 <%= W %> <%= H %>" role="img" aria-label="Bestellungen der letzten 7 Tage">
        <% chart.series.forEach((d, i) => {
          const h = Math.round((d.orders / chart.maxOrders) * (H - pad * 2));
          const x = pad + i * gap + (gap - bw) / 2;
          const y = H - pad - h;
          const day = new Date(); day.setDate(day.getDate() - d.dayOffset);
        %>
          <rect class="bar" x="<%= x.toFixed(1) %>" y="<%= y.toFixed(1) %>" width="<%= bw.toFixed(1) %>" height="<%= Math.max(h,2) %>" rx="5"/>
          <text x="<%= (x + bw/2).toFixed(1) %>" y="<%= H - 6 %>" text-anchor="middle" font-size="11" fill="#969cb0"><%= dayNames[day.getDay()] %></text>
          <% if (d.orders > 0) { %><text x="<%= (x + bw/2).toFixed(1) %>" y="<%= (y - 5).toFixed(1) %>" text-anchor="middle" font-size="11" fill="#f3f4f8" font-weight="700"><%= d.orders %></text><% } %>
        <% }) %>
      </svg>
    </section>

    <section class="admin-section">
      <div class="admin-head-row"><h2>Bestand nach Kategorie</h2><span class="tag"><%= inventoryStats.totalUnits %> Teile</span></div>
      <div class="metric-bars">
        <% inventoryStats.categories.forEach((cat) => { %>
          <div class="metric-bar">
            <div><strong><%= cat.category %></strong><span><%= cat.units %> Teile · <%= price(cat.value_cents) %></span></div>
            <i style="width:<%= Math.max(4, Math.round((cat.units / inventoryStats.maxCategoryUnits) * 100)) %>%"></i>
          </div>
        <% }) %>
        <% if (!inventoryStats.categories.length) { %><p class="muted">Noch keine Bestände.</p><% } %>
      </div>
    </section>
  </div>

  <div class="dashboard-grid">
    <section class="admin-section">
      <div class="admin-head-row"><h2>Kritischer Bestand</h2><a class="btn btn-ghost btn-sm" href="<%- basePath %>/admin/lager">Alle Lagerzeilen</a></div>
      <% if (lowStockWarnings.length === 0) { %>
        <p class="muted">Alles im grünen Bereich.</p>
      <% } else { %>
        <table class="data-table">
          <thead><tr><th>Produkt</th><th>Variante</th><th>Bestand</th><th>Status</th></tr></thead>
          <tbody>
            <% lowStockWarnings.forEach((it) => { %>
              <tr>
                <td><strong><%= it.product_name %></strong><br><span class="muted small"><%= it.category %></span></td>
                <td><%= it.size || 'Standard' %></td>
                <td><strong><%= it.stock %></strong></td>
                <td><span class="tag <%= it.is_out ? '' : 'tag-gold' %>"><%= it.is_out ? 'Ausverkauft' : 'Niedrig' %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </section>

    <section class="admin-section">
      <div class="admin-head-row"><h2>Letzte Bestellungen</h2><a class="btn btn-ghost btn-sm" href="<%- basePath %>/admin/bestellungen">Alle</a></div>
      <% if (recentOrders.length === 0) { %>
        <p class="muted">Noch keine Bestellungen.</p>
      <% } else { %>
        <table class="data-table">
          <thead><tr><th>Referenz</th><th>Kunde</th><th>Summe</th><th>Zahlung</th></tr></thead>
          <tbody>
            <% recentOrders.forEach((o) => { %>
              <tr>
                <td><a href="<%- basePath %>/admin/bestellungen/<%= o.reference %>"><strong><%= o.reference %></strong></a></td>
                <td><%= o.customer_name %></td>
                <td><%= price(o.total_cents) %></td>
                <td><span class="tag <%= o.payment_status === 'bezahlt' ? 'tag-ok' : '' %>"><%= o.payment_status %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </section>
  </div>
</main>

</body>
</html>

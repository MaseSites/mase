<%- include('../partials/head', { adminPage: true, bodyClass: 'admin' }) %>
<%- include('../partials/admin-header') %>

<main class="admin-main narrow">
  <div class="admin-head-row">
    <div>
      <h1>Lager · <%= product.name %></h1>
      <p class="muted">Kategorie: <%= product.category %> · Produktbestand gesamt: <%= product.stock %></p>
    </div>
    <div style="display:flex;gap:.6rem">
      <a class="btn btn-ghost" href="<%- basePath %>/admin/lager">Zurück</a>
      <a class="btn btn-ghost" href="<%- basePath %>/admin/produkte/<%= product.id %>/bearbeiten">Produkt bearbeiten</a>
    </div>
  </div>

  <div id="inv-alert" class="alert alert-error" hidden></div>
  <div id="inv-ok" class="alert alert-ok" hidden>Gespeichert.</div>

  <input type="hidden" id="product-id-val" value="<%= product.id %>">
  <input type="hidden" id="csrf-val" value="<%= csrfToken %>">

  <div class="admin-section">
    <p class="muted">
      Trage für jede Grösse/Variante den Bestand ein.
      Varianten mit Bestand 0 erscheinen im Shop als ausverkauft.
    </p>

    <div style="overflow-x:auto">
      <table class="data-table" id="inv-table">
        <thead>
          <tr>
            <th>Grösse</th>
            <th>Farbe</th>
            <th>SKU</th>
            <th>Bestand</th>
            <th>Reserviert</th>
            <th>Verfügbar</th>
            <th>Minimum</th>
            <th>Lieferung</th>
            <th>Notizen</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="inv-rows">
          <% rows.forEach((r) => { %>
            <tr>
              <td><input class="inv-field" name="size" type="text" value="<%= r.size %>" maxlength="50" placeholder="M"></td>
              <td><input class="inv-field" name="color" type="text" value="<%= r.color %>" maxlength="50" placeholder=""></td>
              <td><input class="inv-field" name="sku" type="text" value="<%= r.sku %>" maxlength="100" placeholder="ABJ-001"></td>
              <td><input class="inv-field inv-stock" name="stock" type="number" min="0" max="999999" value="<%= r.stock %>" style="width:80px"></td>
              <td class="muted"><%= r.reserved %></td>
              <td class="inv-avail"><strong><%= Math.max(0, r.stock - r.reserved) %></strong></td>
              <td><input class="inv-field" name="min_stock" type="number" min="0" max="1000" value="<%= r.min_stock %>" style="width:70px"></td>
              <td><input class="inv-field" name="next_delivery" type="date" value="<%= r.next_delivery %>"></td>
              <td><input class="inv-field" name="notes" type="text" value="<%= r.notes %>" maxlength="500" style="min-width:140px"></td>
              <td><button type="button" class="btn btn-danger btn-sm" data-remove-row>✕</button></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div style="display:flex;gap:.8rem;margin-top:1.2rem;flex-wrap:wrap;">
      <button type="button" class="btn btn-ghost btn-sm" id="add-row">+ Variante hinzufügen</button>
      <% if (product.sizes && product.sizes.length > 0) { %>
        <button type="button" class="btn btn-ghost btn-sm" id="fill-sizes"
                data-sizes="<%- JSON.stringify(product.sizes) %>">
          Grössen aus Produkt übernehmen
        </button>
      <% } %>
      <button type="button" class="btn btn-primary" id="save-inv">Speichern</button>
    </div>
  </div>
</main>

<script src="<%- basePath %>/js/admin.js" defer></script>
<script src="<%- basePath %>/js/inventory.js" defer></script>
</body>
</html>

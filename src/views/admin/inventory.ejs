<%- include('../partials/head', { adminPage: true, bodyClass: 'admin' }) %>
<%- include('../partials/admin-header') %>

<main class="admin-main">
  <div class="admin-head-row">
    <div>
      <p class="admin-kicker">Bestandskontrolle</p>
      <h1>Lager</h1>
    </div>
    <a class="btn btn-primary" href="<%- basePath %>/admin/produkte/neu">+ Neues Produkt</a>
  </div>

  <div class="stat-grid ops-stats">
    <div class="stat-card"><span class="stat-num"><%= analytics.activeProducts %></span><span class="stat-label">aktive Shop-Produkte</span></div>
    <div class="stat-card"><span class="stat-num"><%= analytics.variants %></span><span class="stat-label">Lagerzeilen</span></div>
    <div class="stat-card"><span class="stat-num"><%= analytics.availableUnits %></span><span class="stat-label">verfügbar</span></div>
    <div class="stat-card"><span class="stat-num"><%= analytics.reservedUnits %></span><span class="stat-label">reserviert</span></div>
    <div class="stat-card"><span class="stat-num"><%= price(analytics.stockValueCents) %></span><span class="stat-label">Bestandswert</span></div>
    <div class="stat-card"><span class="stat-num"><%= analytics.outCount %></span><span class="stat-label">ausverkauft</span></div>
  </div>

  <div class="inventory-layout">
    <section class="admin-section">
      <div class="admin-head-row">
        <h2>Bestand nach Kategorie</h2>
        <span class="tag"><%= analytics.totalUnits %> Teile</span>
      </div>
      <div class="metric-bars">
        <% analytics.categories.forEach((cat) => { %>
          <div class="metric-bar">
            <div><strong><%= cat.category %></strong><span><%= cat.units %> Teile · <%= price(cat.value_cents) %></span></div>
            <i style="width:<%= Math.max(4, Math.round((cat.units / analytics.maxCategoryUnits) * 100)) %>%"></i>
          </div>
        <% }) %>
      </div>
    </section>

    <section class="admin-section">
      <div class="admin-head-row"><h2>Warnungen</h2><span class="tag tag-gold"><%= warnings.length %></span></div>
      <% if (warnings.length === 0) { %>
        <p class="muted">Keine kritischen Bestände.</p>
      <% } else { %>
        <div class="warning-list">
          <% warnings.slice(0, 6).forEach((w) => { %>
            <a href="<%- basePath %>/admin/lager/<%= w.product_id %>">
              <strong><%= w.product_name %></strong>
              <span><%= w.size || 'Standard' %> · <%= w.stock %> Stück</span>
            </a>
          <% }) %>
        </div>
      <% } %>
    </section>
  </div>

  <section class="admin-section">
    <div class="inventory-toolbar">
      <input class="admin-search" data-product-filter placeholder="Produkt, Kategorie, SKU oder Variante filtern...">
      <div class="segmented" data-inventory-filter>
        <button type="button" data-status="all" class="active">Alle</button>
        <button type="button" data-status="low">Niedrig</button>
        <button type="button" data-status="out">Ausverkauft</button>
        <button type="button" data-status="ok">OK</button>
      </div>
    </div>

    <% if (items.length === 0) { %>
      <p class="muted">Noch keine aktiven Shop-Produkte.</p>
    <% } else { %>
      <div style="overflow-x:auto">
        <table class="data-table inventory-table">
          <thead>
            <tr>
              <th>Produkt</th>
              <th>Variante</th>
              <th>SKU</th>
              <th>Bestand</th>
              <th>Reserviert</th>
              <th>Verfügbar</th>
              <th>Wert</th>
              <th>Status</th>
              <th>Schnell</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% items.forEach((it) => {
              const unitPrice = it.sale_price_cents != null ? it.sale_price_cents : it.price_cents;
              const value = Math.max(0, it.stock || 0) * Math.max(0, unitPrice || 0);
              const status = it.is_out ? 'out' : it.is_low ? 'low' : 'ok';
            %>
              <tr data-inventory-row data-status="<%= status %>" data-product-id="<%= it.product_id %>" data-size="<%= it.size || '' %>" data-color="<%= it.color || '' %>">
                <td><strong><%= it.product_name %></strong><br><span class="muted small"><%= it.category %></span></td>
                <td><%= it.size || it.color || 'Standard' %></td>
                <td class="muted small"><%= it.sku || '—' %></td>
                <td><strong data-stock><%= it.stock %></strong></td>
                <td class="muted"><%= it.reserved %></td>
                <td><strong data-available><%= it.available %></strong></td>
                <td><%= price(value) %></td>
                <td data-status-cell>
                  <% if (it.is_out) { %><span class="tag">Ausverkauft</span>
                  <% } else if (it.is_low) { %><span class="tag tag-gold">Niedrig</span>
                  <% } else { %><span class="tag tag-ok">OK</span><% } %>
                </td>
                <td>
                  <div class="stock-actions">
                    <button type="button" class="icon-mini" data-stock-adjust="-1" aria-label="Bestand um 1 reduzieren">−</button>
                    <button type="button" class="icon-mini" data-stock-adjust="1" aria-label="Bestand um 1 erhöhen">+</button>
                  </div>
                </td>
                <td><a class="btn btn-ghost btn-sm" href="<%- basePath %>/admin/lager/<%= it.product_id %>">Details</a></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </section>
</main>

<script src="<%- basePath %>/js/admin.js" defer></script>
<script src="<%- basePath %>/js/inventory.js" defer></script>
</body>
</html>

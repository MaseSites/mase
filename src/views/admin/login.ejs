<%- include('../partials/head', { bodyClass: 'gate-page', adminPage: true }) %>

<main class="gate-wrap">
  <div class="gate-card">
    <h1>Admin-Login</h1>
    <p class="muted">Bitte melde dich an, um das Dashboard zu verwalten.</p>

    <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

    <form method="post" action="<%- basePath %>/admin/login" class="gate-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label class="field"><span>Benutzername</span>
        <input type="text" name="username" autocomplete="username" required autofocus></label>
      <label class="field"><span>Passwort</span>
        <input type="password" name="password" autocomplete="current-password" required></label>
      <button class="btn btn-primary btn-block" type="submit">Anmelden</button>
    </form>
  </div>
</main>

</body>
</html>

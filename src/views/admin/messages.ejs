<%- include('../partials/head', { adminPage: true, bodyClass: 'admin' }) %>
<%- include('../partials/admin-header') %>

<main class="admin-main narrow">
  <div class="admin-head-row">
    <h1>Nachrichten</h1>
    <span class="tag"><%= messages.length %> gesamt</span>
  </div>

  <section class="admin-section">
    <% if (messages.length === 0) { %>
      <p class="muted">Noch keine Kontaktnachrichten.</p>
    <% } else { %>
      <div class="msg-list">
        <% messages.forEach((m) => { %>
          <article class="msg-card <%= m.is_read ? '' : 'unread' %>">
            <div class="msg-head">
              <div>
                <strong><%= m.name %></strong>
                <a class="muted" href="mailto:<%= m.email %>"><%= m.email %></a>
              </div>
              <div class="msg-meta">
                <span class="muted small"><%= m.created_at %></span>
                <% if (!m.is_read) { %>
                  <form method="post" action="/admin/nachrichten/gelesen">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <input type="hidden" name="id" value="<%= m.id %>">
                    <button class="btn btn-ghost btn-sm" type="submit">Als gelesen</button>
                  </form>
                <% } else { %><span class="tag tag-off">gelesen</span><% } %>
              </div>
            </div>
            <p class="msg-body"><%= m.body %></p>
          </article>
        <% }) %>
      </div>
    <% } %>
  </section>
</main>

</body>
</html>

<%- include('../partials/head', { adminPage: true, bodyClass: 'admin' }) %>
<%- include('../partials/admin-header') %>

<main class="admin-main narrow">
  <div class="admin-head-row">
    <h1>Newsletter</h1>
    <span class="tag tag-ok"><%= subscribers.length %> Abonnent:innen</span>
  </div>

  <section class="admin-section">
    <% if (subscribers.length === 0) { %>
      <p class="muted">Noch keine Anmeldungen.</p>
    <% } else { %>
      <table class="data-table">
        <thead><tr><th>E-Mail</th><th>Angemeldet</th></tr></thead>
        <tbody>
          <% subscribers.forEach((s) => { %>
            <tr><td><%= s.email %></td><td class="muted"><%= s.created_at %></td></tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </section>
</main>

</body>
</html>

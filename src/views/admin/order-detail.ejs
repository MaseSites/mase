<%- include('../partials/head', { adminPage: true, bodyClass: 'admin' }) %>
<%- include('../partials/admin-header') %>

<main class="admin-main narrow">
  <div class="admin-head-row">
    <h1>Bestellung <%= order.reference %></h1>
    <a class="btn btn-ghost" href="/admin/bestellungen">Zurück</a>
  </div>

  <div class="form-grid">
    <section class="admin-section span-1">
      <h2>Artikel</h2>
      <table class="data-table">
        <tbody>
          <% order.items.forEach((it) => { %>
            <tr>
              <td><%= it.qty %>× <%= it.name %><%= it.size ? ' (' + it.size + ')' : '' %></td>
              <td style="text-align:right"><%= price(it.lineCents != null ? it.lineCents : (it.unitCents * it.qty)) %></td>
            </tr>
          <% }) %>
          <tr><td><strong>Gesamt</strong></td><td style="text-align:right"><strong><%= price(order.total_cents) %></strong></td></tr>
        </tbody>
      </table>
    </section>

    <section class="admin-section span-1">
      <h2>Kunde</h2>
      <p><strong><%= order.customer_name %></strong><br>
        <a href="mailto:<%= order.email %>"><%= order.email %></a></p>
      <p class="muted" style="white-space:pre-line"><%= order.address %></p>
      <p class="muted">Eingegangen: <%= order.created_at %></p>
    </section>
  </div>

  <section class="admin-section">
    <h2>Status verwalten</h2>
    <form method="post" action="/admin/bestellungen/<%= order.reference %>/status" class="admin-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-grid">
        <label class="field"><span>Bestellstatus</span>
          <select name="status">
            <% ['neu','in_bearbeitung','versendet','storniert'].forEach((s) => { %>
              <option value="<%= s %>" <%= order.status === s ? 'selected' : '' %>><%= s.replace('_',' ') %></option>
            <% }) %>
          </select>
        </label>
        <label class="field"><span>Zahlungsstatus</span>
          <select name="payment_status">
            <% ['offen','bezahlt','erstattet'].forEach((s) => { %>
              <option value="<%= s %>" <%= order.payment_status === s ? 'selected' : '' %>><%= s %></option>
            <% }) %>
          </select>
        </label>
      </div>
      <button class="btn btn-primary" type="submit">Status speichern</button>
    </form>
  </section>
</main>

</body>
</html>

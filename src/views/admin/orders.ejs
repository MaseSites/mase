<%- include('../partials/head', { adminPage: true, bodyClass: 'admin' }) %>
<%- include('../partials/admin-header') %>

<main class="admin-main">
  <h1>Bestellungen</h1>

  <% if (orders.length === 0) { %>
    <p class="muted">Noch keine Bestellungen.</p>
  <% } else { %>
    <table class="data-table">
      <thead>
        <tr><th>Referenz</th><th>Kunde</th><th>E-Mail</th><th>Artikel</th><th>Summe</th><th>Zahlung</th><th>Datum</th></tr>
      </thead>
      <tbody>
        <% orders.forEach((o) => { %>
          <tr>
            <td><a href="<%- basePath %>/admin/bestellungen/<%= o.reference %>"><strong><%= o.reference %></strong></a></td>
            <td><%= o.customer_name %></td>
            <td class="muted"><%= o.email %></td>
            <td><%= (o.items || []).reduce((n, i) => n + (i.qty || 0), 0) %></td>
            <td><%= price(o.total_cents) %></td>
            <td><span class="tag"><%= o.payment_status %></span></td>
            <td class="muted"><%= o.created_at %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</main>

</body>
</html>

<%- include('../partials/head', { adminPage: true, bodyClass: 'admin' }) %>
<%- include('../partials/admin-header') %>

<%
  function centsToInput(c) { return c == null ? '' : (c / 100).toFixed(2); }
  const p = product || {};
  const currentOptionGroups = (typeof optionGroups !== 'undefined' && Array.isArray(optionGroups))
    ? optionGroups
    : (Array.isArray(p.option_groups) ? p.option_groups : []);
  const currentVariants = (typeof variants !== 'undefined' && Array.isArray(variants)) ? variants : [];
  const hasVariants = currentOptionGroups.length > 0 || currentVariants.length > 1;
%>

<main class="admin-main product-flow">
  <div class="admin-head-row">
    <div>
      <p class="admin-kicker">Produktverwaltung</p>
      <h1><%= title %></h1>
    </div>
    <a class="btn btn-ghost" href="<%- basePath %>/admin/produkte">Zurück</a>
  </div>

  <div id="form-alert" class="alert alert-error" hidden></div>

  <form id="product-form"
        data-action="<%= formAction %>"
        data-method="<%= method %>"
        data-product-name="<%= p.name || '' %>"
        class="admin-form product-editor">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <section class="admin-section form-step">
      <div class="step-head">
        <span class="step-num">1</span>
        <div>
          <h2>Grunddaten</h2>
          <p class="muted small">Name, Kategorie, Preis und Beschreibung.</p>
        </div>
      </div>

      <div class="form-grid">
        <label class="field span-2"><span>Name *</span>
          <input type="text" name="name" required maxlength="160" value="<%= p.name || '' %>" placeholder="z.B. Vintage Hoodie Black"></label>

        <label class="field"><span>Kategorie</span>
          <input type="text" name="category" maxlength="80" value="<%= p.category || '' %>" placeholder="z.B. Hoodies"></label>

        <label class="field"><span>Preis (€) *</span>
          <input type="text" name="price" inputmode="decimal" value="<%= centsToInput(p.price_cents) %>" placeholder="49.90" required></label>

        <label class="field"><span>Sale-Preis (€) <small class="muted">optional</small></span>
          <input type="text" name="sale_price" inputmode="decimal" value="<%= centsToInput(p.sale_price_cents) %>" placeholder="29.90"></label>

        <label class="field"><span>Lagerbestand</span>
          <input type="number" name="stock" min="0" max="1000000" value="<%= p.stock != null ? p.stock : 0 %>"></label>

        <label class="field span-2"><span>Beschreibung</span>
          <textarea name="description" rows="5" maxlength="8000" placeholder="Material, Zustand, Fit, Lieferumfang..."><%= p.description || '' %></textarea></label>
      </div>
    </section>

    <section class="admin-section form-step">
      <div class="step-head">
        <span class="step-num">2</span>
        <div>
          <h2>Bilder</h2>
          <p class="muted small">Das erste Bild wird im Shop als Hauptbild genutzt.</p>
        </div>
      </div>

      <div class="existing-images" id="existing-images"></div>

      <div class="image-input-grid">
        <label class="field"><span>Bilder hochladen <small class="muted">max. 8 Dateien</small></span>
          <input type="file" name="images" accept="image/*" multiple data-file-input></label>

        <label class="field"><span>Bild-URLs <small class="muted">eine HTTPS-URL pro Zeile</small></span>
          <textarea name="image_urls" rows="4" placeholder="https://..."></textarea></label>
      </div>

      <div class="upload-preview" id="upload-preview"></div>
    </section>

    <section class="admin-section form-step">
      <div class="step-head">
        <span class="step-num">3</span>
        <div>
          <h2>Lager & Varianten</h2>
          <p class="muted small">Für normale Produkte reicht der Lagerbestand oben. Für Größen, Farben oder andere Auswahlmöglichkeiten Varianten aktivieren.</p>
        </div>
      </div>

      <label class="switch-row">
        <input type="checkbox" name="has_variants" value="1" <%= hasVariants ? 'checked' : '' %>>
        <span>
          <strong>Varianten aktivieren</strong>
          <small>Größen, Farben oder eigene Varianten mit separatem Bestand.</small>
        </span>
      </label>

      <div class="option-builder" id="option-builder">
        <div class="option-toolbar">
          <button type="button" class="btn btn-ghost btn-sm" data-add-option="size">Größen hinzufügen</button>
          <button type="button" class="btn btn-ghost btn-sm" data-add-option="color">Farben hinzufügen</button>
          <button type="button" class="btn btn-ghost btn-sm" data-add-option="custom">Eigene Option</button>
        </div>

        <div id="option-groups-list" class="option-groups-list"></div>

        <div class="variant-preview-head">
          <h3>Varianten</h3>
          <p class="muted small">Jede Kombination bekommt eigenen Bestand, optional SKU, Preis und Bild.</p>
        </div>
        <div id="variant-preview" class="variant-preview"></div>
      </div>
    </section>

    <section class="admin-section form-step">
      <div class="step-head">
        <span class="step-num">4</span>
        <div>
          <h2>Status</h2>
          <p class="muted small">Steuere, ob das Produkt direkt im Shop erscheint.</p>
        </div>
      </div>

      <div class="checkbox-row">
        <label class="checkbox"><input type="checkbox" name="is_active" value="1" <%= (!product || p.is_active) ? 'checked' : '' %>> Aktiv im Shop</label>
        <label class="checkbox"><input type="checkbox" name="is_bestseller" value="1" <%= p.is_bestseller ? 'checked' : '' %>> Bestseller</label>
      </div>
    </section>

    <div class="sticky-save">
      <div>
        <strong><%= product ? 'Änderungen speichern' : 'Produkt erstellen' %></strong>
        <span class="muted small">Nach dem Speichern kommst du zurück zur Produktliste.</span>
      </div>
      <div class="form-footer">
        <a class="btn btn-ghost" href="<%- basePath %>/admin/produkte">Abbrechen</a>
        <button class="btn btn-primary" type="submit">Speichern</button>
      </div>
    </div>
  </form>

  <script type="application/json" id="existing-images-data">
    <%- JSON.stringify((p.images || [])) %>
  </script>
  <script type="application/json" id="existing-option-groups-data">
    <%- JSON.stringify(currentOptionGroups) %>
  </script>
  <script type="application/json" id="existing-variants-data">
    <%- JSON.stringify(currentVariants.map((v) => ({
      id: v.id,
      sku: v.sku || '',
      size: v.size || '',
      color: v.color || '',
      stock: v.stock || 0,
      min_stock: v.min_stock || 3,
      next_delivery: v.next_delivery || '',
      notes: v.notes || '',
      title: v.title || '',
      option_values: (function(){ try { return JSON.parse(v.option_values || '[]'); } catch(e) { return []; } })(),
      images: (function(){ try { return JSON.parse(v.images || '[]'); } catch(e) { return []; } })(),
      variant_price_cents: v.variant_price_cents != null ? v.variant_price_cents : null,
      is_default: !!v.is_default,
    }))) %>
  </script>
</main>

<script src="<%- basePath %>/js/admin.js" defer></script>
</body>
</html>

<%- include('../partials/head', { adminPage: true, bodyClass: 'admin' }) %>
<%- include('../partials/admin-header') %>

<main class="admin-main">
  <div class="admin-head-row">
    <h1>Produkte</h1>
    <a class="btn btn-primary" href="/admin/produkte/neu">+ Neues Produkt</a>
  </div>

  <% if (items.length) { %>
    <input type="search" class="admin-search" data-product-filter placeholder="Produkte filtern… (Name, Kategorie, Status)" aria-label="Produkte filtern">
  <% } %>

  <% if (items.length === 0) { %>
    <p class="muted">Noch keine Produkte. Lege das erste an.</p>
  <% } else { %>
    <table class="data-table">
      <thead>
        <tr><th>Bild</th><th>Name</th><th>Kategorie</th><th>Preis</th><th>Lager</th><th>Status</th><th></th></tr>
      </thead>
      <tbody>
        <% items.forEach((p) => { %>
          <tr>
            <td class="cell-img">
              <img src="<%= (p.images && p.images[0]) ? p.images[0].src : placeholder(p.name) %>" alt="">
            </td>
            <td>
              <strong><%= p.name %></strong>
              <% if (p.is_bestseller) { %><span class="tag tag-gold">Bestseller</span><% } %>
            </td>
            <td><%= p.category %></td>
            <td>
              <% if (p.sale_price_cents) { %><span class="price-sale"><%= price(p.sale_price_cents) %></span> <span class="price-old"><%= price(p.price_cents) %></span><% } else { %><%= price(p.price_cents) %><% } %>
            </td>
            <td><%= p.stock %></td>
            <td><span class="tag <%= p.is_active ? 'tag-ok' : 'tag-off' %>"><%= p.is_active ? 'aktiv' : 'inaktiv' %></span></td>
            <td class="cell-actions">
              <a class="btn btn-ghost btn-sm" href="/admin/produkte/<%= p.id %>/bearbeiten">Bearbeiten</a>
              <button class="btn btn-danger btn-sm" data-delete-product="<%= p.id %>" data-name="<%= p.name %>">Löschen</button>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</main>

<script src="/js/admin.js" defer></script>
</body>
</html>

<%- include('../partials/head', { adminPage: true, bodyClass: 'admin' }) %>
<%- include('../partials/admin-header') %>

<main class="admin-main narrow">
  <h1>Einstellungen</h1>

  <% if (notice) { %><div class="alert alert-ok"><%= notice %></div><% } %>
  <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

  <section class="admin-section">
    <h2>Shop</h2>
    <form method="post" action="<%- basePath %>/admin/einstellungen" class="admin-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-grid">
        <label class="field span-2"><span>Shop-Name</span>
          <input type="text" name="shop_name" value="<%= settings.shop_name %>" maxlength="120" required></label>
        <label class="field span-2"><span>Slogan</span>
          <input type="text" name="tagline" value="<%= settings.tagline %>" maxlength="200"></label>
        <label class="field span-2"><span>Hero-Titel</span>
          <input type="text" name="hero_title" value="<%= settings.hero_title %>" maxlength="200"></label>
        <label class="field span-2"><span>Hero-Untertitel</span>
          <input type="text" name="hero_subtitle" value="<%= settings.hero_subtitle %>" maxlength="400"></label>
        <label class="field span-2"><span>Sale-Countdown bis <small class="muted">(z.B. 2026-06-30T23:59)</small></span>
          <input type="datetime-local" name="sale_ends_at" value="<%= settings.sale_ends_at %>"></label>
        <label class="field"><span>Mitglieder-Zahl</span>
          <input type="number" name="members_count" value="<%= settings.members_count %>" min="0"></label>
        <label class="field"><span>Bewertungs-Zahl</span>
          <input type="number" name="ratings_count" value="<%= settings.ratings_count %>" min="0"></label>
        <label class="field span-2"><span>Kontakt-E-Mail</span>
          <input type="email" name="contact_email" value="<%= settings.contact_email %>" maxlength="200" required></label>
        <label class="field span-2"><span>Ankündigungs-Leiste <small class="muted">(oben auf jeder Seite, leer = aus)</small></span>
          <input type="text" name="announcement" value="<%= settings.announcement %>" maxlength="200"></label>
        <label class="field span-2"><span>Hero-Bild <small class="muted">(Pfad /assets/hero.jpg oder HTTPS-URL)</small></span>
          <input type="text" name="hero_image" value="<%= settings.hero_image %>" maxlength="400"></label>

        <div class="field span-2"><span>Theme-Farben (Akzent / Verlauf)</span>
          <div class="color-row" data-color-row
               data-a="<%= settings.accent %>" data-b="<%= settings.accent_2 %>" data-c="<%= settings.accent_3 %>">
            <label class="color-pick"><input type="color" name="accent" value="<%= settings.accent %>" data-color="a"><span>Primär</span></label>
            <label class="color-pick"><input type="color" name="accent_2" value="<%= settings.accent_2 %>" data-color="b"><span>Sekundär</span></label>
            <label class="color-pick"><input type="color" name="accent_3" value="<%= settings.accent_3 %>" data-color="c"><span>Akzent 3</span></label>
            <span class="color-preview" data-color-preview></span>
          </div>
        </div>
      </div>
      <button class="btn btn-primary" type="submit">Speichern</button>
    </form>
  </section>

  <section class="admin-section">
    <h2>Passwörter</h2>
    <div class="form-grid">
      <form method="post" action="<%- basePath %>/admin/passwort" class="admin-form span-1">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="which" value="admin">
        <label class="field"><span>Neues Admin-Passwort</span>
          <input type="password" name="new_password" minlength="6" maxlength="200" required autocomplete="new-password"></label>
        <button class="btn btn-ghost" type="submit">Admin-Passwort ändern</button>
      </form>

      <form method="post" action="<%- basePath %>/admin/passwort" class="admin-form span-1">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="which" value="gate">
        <label class="field"><span>Neues Zugangs-Passwort (Seiten-Sperre)</span>
          <input type="password" name="new_password" minlength="6" maxlength="200" required autocomplete="new-password"></label>
        <button class="btn btn-ghost" type="submit">Zugangs-Passwort ändern</button>
      </form>
    </div>
  </section>
</main>

</body>
</html>

<%- include('../partials/head', { bodyClass: 'gate-page' }) %>

<main class="gate-wrap">
  <div class="gate-card">
    <h1><%= shopName %></h1>
    <p class="muted">Diese Seite ist noch nicht öffentlich. Bitte gib das Zugangs-Passwort ein.</p>

    <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

    <form method="post" action="<%- basePath %>/gate" class="gate-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label class="field">
        <span>Zugangs-Passwort</span>
        <input type="password" name="password" autocomplete="current-password" required autofocus>
      </label>
      <button class="btn btn-primary btn-block" type="submit">Eintreten</button>
    </form>
  </div>
</main>

</body>
</html>

<header class="admin-topbar">
  <div class="admin-topbar-inner">
    <a class="admin-brand" href="<%- basePath %>/admin"><%= shopName %> · Admin</a>
    <nav class="admin-nav">
      <a href="<%- basePath %>/admin" class="<%= path === basePath + '/admin' ? 'active' : '' %>">Übersicht</a>
      <a href="<%- basePath %>/admin/produkte" class="<%= path.startsWith(basePath + '/admin/produkte') ? 'active' : '' %>">Produkte</a>
      <a href="<%- basePath %>/admin/lager" class="<%= path.startsWith(basePath + '/admin/lager') ? 'active' : '' %>">Lager</a>
      <a href="<%- basePath %>/admin/bestellungen" class="<%= path.startsWith(basePath + '/admin/bestellungen') ? 'active' : '' %>">Bestellungen</a>
      <a href="<%- basePath %>/admin/nachrichten" class="<%= path.startsWith(basePath + '/admin/nachrichten') ? 'active' : '' %>">Nachrichten</a>
      <a href="<%- basePath %>/admin/newsletter" class="<%= path.startsWith(basePath + '/admin/newsletter') ? 'active' : '' %>">Newsletter</a>
      <a href="<%- basePath %>/admin/einstellungen" class="<%= path.startsWith(basePath + '/admin/einstellungen') ? 'active' : '' %>">Einstellungen</a>
    </nav>
    <div class="admin-actions">
      <a href="<%- basePath %>" target="_blank" rel="noopener">Shop ansehen</a>
      <form method="post" action="<%- basePath %>/admin/logout">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button class="btn btn-ghost btn-sm" type="submit">Abmelden</button>
      </form>
    </div>
  </div>
</header>

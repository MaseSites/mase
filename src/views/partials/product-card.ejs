<article class="product-card" data-product-card>
  <div class="product-card-media">
    <a href="/produkt/<%= p.slug %>" class="media-link" aria-label="<%= p.name %>">
      <img src="<%= (p.images && p.images[0]) ? p.images[0].src : placeholder(p.name) %>" alt="<%= p.name %>" loading="lazy">
      <span class="card-shine" aria-hidden="true"></span>
    </a>
    <% if (p.sale_price_cents) { %>
      <span class="badge-sale">-<%= discountPercent(p.price_cents, p.sale_price_cents) %>%</span>
    <% } %>
    <% if (p.stock <= 0) { %>
      <span class="badge-soldout">Ausverkauft</span>
    <% } %>

    <button class="wish-btn" data-wish="<%= p.id %>" aria-label="Zur Wunschliste" title="Merken">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 21s-7-4.5-9.5-9A5 5 0 0 1 12 6a5 5 0 0 1 9.5 6c-2.5 4.5-9.5 9-9.5 9z"/></svg>
    </button>

    <% if (p.stock > 0) { %>
      <button class="quick-add"
              data-quick-add
              data-id="<%= p.id %>"
              data-slug="<%= p.slug %>"
              data-has-sizes="<%= (p.sizes && p.sizes.length) ? '1' : '0' %>">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
        <span>In den Warenkorb</span>
      </button>
    <% } %>
  </div>
  <div class="product-card-body">
    <span class="product-cat"><%= p.category %></span>
    <h3 class="product-name"><a href="/produkt/<%= p.slug %>"><%= p.name %></a></h3>
    <div class="product-price">
      <% if (p.sale_price_cents) { %>
        <span class="price-sale"><%= price(p.sale_price_cents) %></span>
        <span class="price-old"><%= price(p.price_cents) %></span>
      <% } else { %>
        <span class="price-now"><%= price(p.price_cents) %></span>
      <% } %>
    </div>
  </div>
</article>

<%- include('../partials/head') %>
<%- include('../partials/site-header') %>

<main id="main" class="container section">
  <h1 class="section-title">Warenkorb</h1>

  <% if (typeof warnings !== 'undefined' && warnings.length > 0) { %>
    <div class="alert alert-error" style="margin-bottom:1.4rem">
      <% warnings.forEach((w) => { %>
        <div><%= w.message || 'Ein Artikel ist nicht mehr verfügbar.' %></div>
      <% }) %>
    </div>
  <% } %>

  <% if (items.length === 0 || items.every(it => it.qty === 0)) { %>
    <div class="cart-empty-state">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="56" height="56"><path d="M6 7h12l-1 13H7zM9 7a3 3 0 0 1 6 0"/></svg>
      <p>Dein Warenkorb ist leer.</p>
      <a class="btn btn-primary" href="/shop">Zum Shop</a>
    </div>
  <% } else { %>
    <div class="cart-table">
      <% items.forEach((it, i) => { if (it.qty === 0 && !it.isSoldOut) return; %>
        <div class="cart-row<%= it.isSoldOut ? ' is-soldout' : '' %>">
          <div class="cart-media">
            <img src="<%= it.image || placeholder(it.name) %>" alt="<%= it.name %>">
          </div>
          <div class="cart-info">
            <a href="/produkt/<%= it.slug %>"><strong><%= it.name %></strong></a>
            <% if (it.size) { %><span class="muted">Grösse: <%= it.size %></span><% } %>
            <span class="muted"><%= price(it.unitCents) %> / Stück</span>
            <% if (it.isSoldOut) { %>
              <span class="cart-soldout-label">Ausverkauft – wird beim Checkout entfernt</span>
            <% } else if (it.wasReduced) { %>
              <span class="cart-reduced-warning">Menge auf <%= it.qty %> reduziert (max. verfügbar)</span>
            <% } %>
          </div>
          <% if (!it.isSoldOut) { %>
            <form class="cart-qty" method="post" action="/warenkorb/update">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <input type="hidden" name="index" value="<%= i %>">
              <input type="number" name="qty" value="<%= it.qty %>" min="0" max="<%= it.maxQty %>" aria-label="Menge">
              <button class="btn btn-ghost btn-sm" type="submit">OK</button>
            </form>
            <div class="cart-line-total"><%= price(it.lineCents) %></div>
          <% } %>
        </div>
      <% }) %>
    </div>

    <div class="cart-summary">
      <form method="post" action="/warenkorb/clear">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button class="btn btn-ghost" type="submit">Leeren</button>
      </form>
      <div class="cart-total">
        <span>Gesamt</span>
        <strong><%= price(total) %></strong>
      </div>
      <a class="btn btn-primary" href="/kasse">Zur Kasse</a>
    </div>
  <% } %>
</main>

<%- include('../partials/site-footer') %>

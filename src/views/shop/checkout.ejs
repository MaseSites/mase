<%- include('../partials/head') %>
<%- include('../partials/site-header') %>

<main id="main" class="container section narrow">
  <h1 class="section-title">Kasse</h1>

  <% if (errors) { %>
    <div class="alert alert-error">
      <% errors.forEach((e) => { %><div><%= e.message %></div><% }) %>
    </div>
  <% } %>

  <div class="checkout-grid">
    <form method="post" action="/kasse" class="checkout-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label class="field">
        <span>Name</span>
        <input type="text" name="name" value="<%= values.name || '' %>" required maxlength="120">
      </label>
      <label class="field">
        <span>E-Mail</span>
        <input type="email" name="email" value="<%= values.email || '' %>" required maxlength="200">
      </label>
      <label class="field">
        <span>Lieferadresse</span>
        <textarea name="address" rows="3" required maxlength="500"><%= values.address || '' %></textarea>
      </label>
      <p class="muted small">Hinweis: Aktuell ohne Online-Zahlung. Du erhältst eine Bestätigung; die Zahlung wird separat abgewickelt.</p>
      <button class="btn btn-primary" type="submit">Bestellung abschließen</button>
    </form>

    <aside class="order-summary">
      <h3>Übersicht</h3>
      <% items.forEach((it) => { %>
        <div class="summary-row">
          <span><%= it.qty %>× <%= it.name %><%= it.size ? ' (' + it.size + ')' : '' %></span>
          <span><%= price(it.lineCents) %></span>
        </div>
      <% }) %>
      <div class="summary-total">
        <span>Gesamt</span><strong><%= price(total) %></strong>
      </div>
      <ul class="checkout-trust">
        <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="10" rx="2"/><path d="M7 11V8a5 5 0 0 1 10 0v3"/></svg> SSL-verschlüsselt & sicher</li>
        <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 1 0 9-9"/><path d="M3 4v5h5"/></svg> 14 Tage Rückgaberecht</li>
        <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3l8 4v5c0 4.5-3 7.5-8 9-5-1.5-8-4.5-8-9V7z"/><path d="M9 12l2 2 4-4"/></svg> Käuferschutz inklusive</li>
      </ul>
    </aside>
  </div>
</main>

<%- include('../partials/site-footer') %>

<%- include('../partials/head') %>
<%- include('../partials/site-header') %>

<main id="main" class="container section narrow">
  <h1 class="section-title">Kontakt</h1>

  <% if (sent) { %>
    <div class="alert alert-ok">Danke! Deine Nachricht wurde übermittelt – wir melden uns bald.</div>
  <% } %>
  <% if (typeof errors !== 'undefined' && errors) { %>
    <div class="alert alert-error"><% errors.forEach((e) => { %><div><%= e.message %></div><% }) %></div>
  <% } %>

  <p class="muted">Schreib uns – wir melden uns so schnell wie möglich.
    Direkt: <a href="mailto:<%= contactEmail %>"><%= contactEmail %></a></p>

  <form method="post" action="/kontakt" class="checkout-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label class="field"><span>Name</span><input type="text" name="name" value="<%= (typeof values !== 'undefined' && values.name) || '' %>" required maxlength="120"></label>
    <label class="field"><span>E-Mail</span><input type="email" name="email" value="<%= (typeof values !== 'undefined' && values.email) || '' %>" required maxlength="200"></label>
    <label class="field"><span>Nachricht</span><textarea name="message" rows="5" required maxlength="2000"><%= (typeof values !== 'undefined' && values.message) || '' %></textarea></label>
    <button class="btn btn-primary" type="submit">Senden</button>
  </form>
</main>

<%- include('../partials/site-footer') %>

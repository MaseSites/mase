<%- include('../partials/head') %>
<%- include('../partials/site-header') %>

<main id="main">
  <section class="hero">
    <div class="hero-media" aria-hidden="true"></div>
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="container hero-inner">
      <p class="hero-eyebrow">Designer &amp; Streetwear · Authentifiziert</p>
      <h1 class="hero-title"><%= settings_hero_title %></h1>
      <p class="hero-sub"><%= settings_hero_sub %></p>
      <div class="hero-cta">
        <a class="btn btn-primary" href="/shop">Kollektion ansehen</a>
        <a class="btn btn-line" href="/shop">Neuheiten</a>
      </div>
      <div class="hero-rating">
        <span class="stars" aria-hidden="true">★★★★★</span>
        <span><strong>4,9/5</strong> · <strong><%= Number(ratingsCount).toLocaleString('de-DE') %>+</strong> verifizierte Bewertungen</span>
      </div>
    </div>
  </section>

  <section class="brand-marquee" aria-label="Geführte Marken">
    <div class="brand-track">
      <% const brands = ['MONCLER','STONE ISLAND','REPRESENT','FEAR OF GOD','C.P. COMPANY','CANADA GOOSE','TRAPSTAR','ESSENTIALS','AMIRI','OFF-WHITE','RALPH LAUREN','BALENCIAGA'];
         for (let r = 0; r < 2; r++) { brands.forEach((b) => { %>
        <span class="brand-name"><%= b %></span>
      <% }) } %>
    </div>
  </section>

  <section class="container trust-strip" aria-label="Vorteile">
    <div class="trust-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="10" rx="2"/><path d="M7 11V8a5 5 0 0 1 10 0v3"/></svg>
      <div><strong>Sichere Bezahlung</strong><span>SSL-verschlüsselt</span></div>
    </div>
    <div class="trust-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7h13v8H3zM16 10h3l2 3v2h-5z"/><circle cx="6.5" cy="17.5" r="1.5"/><circle cx="17.5" cy="17.5" r="1.5"/></svg>
      <div><strong>EU-Express-Versand</strong><span>2–5 Werktage</span></div>
    </div>
    <div class="trust-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 1 0 9-9"/><path d="M3 4v5h5"/><path d="M9 12l2 2 4-4"/></svg>
      <div><strong>14 Tage Rückgabe</strong><span>einfach & fair</span></div>
    </div>
    <div class="trust-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3l8 4v5c0 4.5-3 7.5-8 9-5-1.5-8-4.5-8-9V7z"/><path d="M9 12l2 2 4-4"/></svg>
      <div><strong>Käuferschutz</strong><span>100% Geld-zurück</span></div>
    </div>
  </section>

  <section class="container section">
    <div class="feature-grid">
      <div class="feature-card reveal">
        <div class="feature-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-6 9 6v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg></div>
        <h3>Kuratierte Auswahl</h3>
        <p>Handverlesene Vintage- & Premium-Teile in limitierter Stückzahl.</p>
      </div>
      <div class="feature-card reveal">
        <div class="feature-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg></div>
        <h3>Geprüfte Qualität</h3>
        <p>Jedes Stück wird vor dem Versand kontrolliert.</p>
      </div>
      <div class="feature-card reveal">
        <div class="feature-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7h13v8H3zM16 10h3l2 3v2h-5z"/><circle cx="6.5" cy="17.5" r="1.5"/><circle cx="17.5" cy="17.5" r="1.5"/></svg></div>
        <h3>Schneller Versand</h3>
        <p>EU-weiter Express – sicher verpackt und nachverfolgbar.</p>
      </div>
      <div class="feature-card reveal">
        <div class="feature-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="10" rx="2"/><path d="M7 11V8a5 5 0 0 1 10 0v3"/></svg></div>
        <h3>Sicher einkaufen</h3>
        <p>Verschlüsselte Verbindung und geschützte Daten.</p>
      </div>
    </div>
  </section>

  <% if (categories.length) { %>
  <section class="container section">
    <h2 class="section-title">Kategorien</h2>
    <div class="chip-row">
      <% categories.forEach((c) => { %>
        <a class="chip" href="/shop?category=<%= encodeURIComponent(c) %>"><%= c %></a>
      <% }) %>
    </div>
  </section>
  <% } %>

  <% if (featured.length) { %>
  <section class="container section">
    <h2 class="section-title">Bestseller</h2>
    <div class="product-grid">
      <% featured.forEach((p) => { %>
        <%- include('../partials/product-card', { p }) %>
      <% }) %>
    </div>
  </section>
  <% } %>

  <section class="container section">
    <h2 class="section-title">Neu eingetroffen</h2>
    <% if (latest.length) { %>
      <div class="product-grid">
        <% latest.forEach((p) => { %>
          <%- include('../partials/product-card', { p }) %>
        <% }) %>
      </div>
    <% } else { %>
      <p class="muted">Neue Drops sind in Vorbereitung – schau bald wieder vorbei!</p>
    <% } %>
  </section>

  <% if (categories.length) { %>
  <section class="container section">
    <h2 class="section-title">Kollektionen entdecken</h2>
    <div class="collection-grid">
      <% categories.slice(0, 6).forEach((c, i) => { %>
        <a class="collection-card reveal" href="/shop?category=<%= encodeURIComponent(c) %>" data-coll="<%= i %>">
          <span class="collection-name"><%= c %></span>
          <span class="collection-go">Ansehen →</span>
        </a>
      <% }) %>
    </div>
  </section>
  <% } %>

  <section class="container section">
    <h2 class="section-title">Was unsere Kund:innen sagen</h2>
    <div class="testimonial-grid">
      <% [
        { n: 'Lena M.', t: 'Qualität deutlich besser als erwartet. Die Box war jeden Cent wert!', r: 5 },
        { n: 'Jonas K.', t: 'Schneller Versand, top verpackt. Werde definitiv wieder bestellen.', r: 5 },
        { n: 'Sara B.', t: 'Endlich Vintage, das wirklich kuratiert ist. Absolute Empfehlung.', r: 5 }
      ].forEach((rev) => { %>
        <figure class="testimonial reveal">
          <div class="stars" aria-label="<%= rev.r %> von 5 Sternen"><% for (let s=0;s<rev.r;s++){ %>★<% } %></div>
          <blockquote><%= rev.t %></blockquote>
          <figcaption><span class="avatar"><%= rev.n[0] %></span><%= rev.n %> · verifiziert</figcaption>
        </figure>
      <% }) %>
    </div>
  </section>

  <section class="container section">
    <h2 class="section-title">Häufige Fragen</h2>
    <div class="faq">
      <% [
        { q: 'Wie lange dauert der Versand?', a: 'In der Regel 2–5 Werktage innerhalb der EU. Du erhältst eine Sendungsverfolgung.' },
        { q: 'Was ist in einer Mystery-Box enthalten?', a: 'Kuratierte Vintage- und Markenteile passend zur gewählten Größe – der Warenwert übersteigt den Boxpreis.' },
        { q: 'Kann ich umtauschen?', a: 'Ja, innerhalb von 14 Tagen. Kontaktiere uns einfach über die Kontaktseite.' },
        { q: 'Wie bezahle ich?', a: 'Aktuell schließt du die Bestellung ab und erhältst die Zahlungsdetails per Bestätigung. Online-Zahlung folgt in Kürze.' }
      ].forEach((f) => { %>
        <details class="faq-item">
          <summary><%= f.q %><span class="faq-ic" aria-hidden="true"></span></summary>
          <div class="faq-a"><%= f.a %></div>
        </details>
      <% }) %>
    </div>
  </section>

  <section class="container section" data-recent-section hidden>
    <h2 class="section-title">Zuletzt angesehen</h2>
    <div class="product-grid" data-recent-grid></div>
  </section>

  <section class="container section" id="newsletter">
    <div class="newsletter reveal">
      <div class="newsletter-text">
        <h2>Sichere dir die nächsten Drops</h2>
        <p class="muted">Trag dich ein und erfahre als Erste:r von neuen Boxen & exklusiven Rabatten.</p>
      </div>
      <form class="newsletter-form" action="/newsletter" method="post" data-newsletter>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="email" name="email" placeholder="deine@email.de" required maxlength="200" aria-label="E-Mail">
        <button class="btn btn-primary" type="submit">Anmelden</button>
      </form>
      <% if (newsletterDone) { %><p class="newsletter-done">✓ Danke! Du bist dabei.</p><% } %>
    </div>
  </section>
</main>

<%- include('../partials/site-footer') %>

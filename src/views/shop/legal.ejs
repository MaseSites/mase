<%- include('../partials/head') %>
<%- include('../partials/site-header') %>

<main id="main" class="container section narrow legal">
  <h1 class="section-title"><%= page.title %></h1>
  <p class="muted"><%= page.intro %></p>

  <% page.sections.forEach((s) => { %>
    <section class="legal-section">
      <h2><%= s.h %></h2>
      <p><%= s.body %></p>
    </section>
  <% }) %>

  <p class="muted small legal-note">Hinweis: Dies ist eine Vorlage und ersetzt keine Rechtsberatung. Bitte vor dem Live-Gang von einer fachkundigen Person prüfen lassen.</p>
</main>

<%- include('../partials/site-footer') %>

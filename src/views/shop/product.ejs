<%- include('../partials/head') %>
<%- include('../partials/site-header') %>

<main id="main" class="container section">
  <nav class="breadcrumb muted"><a href="/shop">Shop</a> / <a href="/shop?category=<%= encodeURIComponent(product.category) %>"><%= product.category %></a> / <span><%= product.name %></span></nav>

  <div class="product-detail" data-track-view="<%= product.id %>">
    <div class="gallery" data-gallery>
      <% if (product.images && product.images.length) { %>
        <div class="gallery-main">
          <img src="<%= product.images[0].src %>" alt="<%= product.name %>" data-gallery-main data-zoomable>
          <span class="zoom-hint" aria-hidden="true">Klicken zum Vergrößern</span>
        </div>
        <% if (product.images.length > 1) { %>
          <div class="gallery-thumbs">
            <% product.images.forEach((img, i) => { %>
              <button type="button" class="thumb <%= i === 0 ? 'active' : '' %>" data-src="<%= img.src %>">
                <img src="<%= img.src %>" alt="Ansicht <%= i + 1 %>" loading="lazy">
              </button>
            <% }) %>
          </div>
        <% } %>
      <% } else { %>
        <div class="gallery-main">
          <img src="<%= placeholder(product.name) %>" alt="<%= product.name %>">
        </div>
      <% } %>
    </div>

    <div class="product-info">
      <p class="product-cat-label"><%= product.category %></p>
      <h1 class="product-detail-name"><%= product.name %></h1>

      <%
        const hasSale = !!product.sale_price_cents;
        const pct = hasSale ? discountPercent(product.price_cents, product.sale_price_cents) : 0;
      %>
      <div class="product-price big">
        <% if (hasSale) { %>
          <span class="price-sale"><%= price(product.sale_price_cents) %></span>
          <span class="price-old"><%= price(product.price_cents) %></span>
          <% if (pct > 0) { %><span class="badge-sale">-<%= pct %>%</span><% } %>
        <% } else { %>
          <span class="price-now"><%= price(product.price_cents) %></span>
        <% } %>
      </div>

      <% if (product.stock > 0) { %>

        <%
          // Bestand pro Grösse aus inventoryMap (vom Server geliefert)
          // inventoryMap: { "M": 5, "L": 2, ... } or {} falls keine Inventory-Daten
          const invMap = typeof inventoryMap !== 'undefined' ? inventoryMap : {};
          const hasInv = Object.keys(invMap).length > 0;
        %>

        <% if (product.stock <= 5) { %>
          <p class="stock-urgency">Nur noch <strong><%= product.stock %></strong> Stück verfügbar – schnell sein!</p>
        <% } %>

        <% if (typeof errorParam !== 'undefined' && errorParam === 'size') { %>
          <p class="alert alert-error" style="margin:.5rem 0;">Bitte Grösse wählen.</p>
        <% } %>
        <% if (typeof errorParam !== 'undefined' && errorParam === 'soldout') { %>
          <p class="alert alert-error" style="margin:.5rem 0;">Diese Variante ist leider ausverkauft.</p>
        <% } %>

        <form method="post" action="/warenkorb/add" class="add-form"
              data-ajax-add data-product-id="<%= product.id %>"
              data-has-sizes="<%= (product.sizes && product.sizes.length) ? '1' : '0' %>">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="productId" value="<%= product.id %>">

          <% if (product.sizes && product.sizes.length) { %>
            <label class="field-label">Grösse <span class="muted">(Pflicht)</span></label>
            <div class="size-row" role="radiogroup" aria-label="Grösse wählen">
              <% product.sizes.forEach((s) => {
                const sizeAvail = hasInv ? (invMap[s] || 0) : (product.stock > 0 ? 1 : 0);
                const disabled = sizeAvail <= 0;
              %>
                <label class="size-option <%= disabled ? 'size-disabled' : '' %>">
                  <input type="radio" name="size" value="<%= s %>"
                         <%= disabled ? 'disabled' : '' %>
                         aria-label="Grösse <%= s %><%= disabled ? ' ausverkauft' : '' %>">
                  <span title="<%= disabled ? 'Ausverkauft' : sizeAvail + ' verfügbar' %>">
                    <%= s %>
                    <% if (!disabled && hasInv && sizeAvail <= 3) { %>
                      <small class="size-qty">(<%= sizeAvail %>)</small>
                    <% } %>
                  </span>
                </label>
              <% }) %>
            </div>
          <% } %>

          <label class="field-label" for="qty">Menge</label>
          <input class="qty-input" id="qty" type="number" name="qty"
                 value="1" min="1" max="<%= product.stock %>"
                 data-max-stock="<%= product.stock %>">

          <button class="btn btn-primary" type="submit">In den Warenkorb</button>
        </form>
      <% } else { %>
        <p class="sold-out-label">Ausverkauft</p>
      <% } %>

      <div class="product-trust-row">
        <span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M12 3l8 4v5c0 4.5-3 7.5-8 9-5-1.5-8-4.5-8-9V7z"/></svg>
          Authentizität garantiert
        </span>
        <span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M3 7h13v8H3zM16 10h3l2 3v2h-5z"/><circle cx="6.5" cy="17.5" r="1.5"/><circle cx="17.5" cy="17.5" r="1.5"/></svg>
          EU-Versand
        </span>
        <span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M3 12a9 9 0 1 0 9-9"/><path d="M3 4v5h5"/></svg>
          14 Tage Rückgabe
        </span>
      </div>

      <% if (product.description) { %>
        <div class="product-description"><%- product.description %></div>
      <% } %>
    </div>
  </div>

  <% if (related && related.length) { %>
    <section class="related">
      <h2 class="section-title">Das könnte dir auch gefallen</h2>
      <div class="product-grid">
        <% related.forEach((p) => { %>
          <%- include('../partials/product-card', { p }) %>
        <% }) %>
      </div>
    </section>
  <% } %>
</main>

<%- include('../partials/site-footer') %>

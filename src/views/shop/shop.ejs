<%- include('../partials/head') %>
<%- include('../partials/site-header') %>

<main id="main" class="container section">
  <h1 class="section-title"><%= query ? 'Suchergebnisse' : 'Shop' %></h1>
  <% if (query) { %>
    <p class="muted result-info">
      <strong><%= total %></strong> Treffer für „<%= query %>" ·
      <a href="<%- basePath %>/shop">Suche zurücksetzen</a>
    </p>
  <% } %>

  <div class="shop-toolbar">
    <div class="chip-row">
      <a class="chip <%= !activeCategory ? 'active' : '' %>" href="<%- basePath %>/shop">Alle</a>
      <% categories.forEach((c) => { %>
        <a class="chip <%= activeCategory === c ? 'active' : '' %>" href="<%- basePath %>/shop?category=<%= encodeURIComponent(c) %>"><%= c %></a>
      <% }) %>
    </div>
    <form class="sort-form" method="get" action="<%- basePath %>/shop" data-sort-form>
      <% if (query) { %><input type="hidden" name="q" value="<%= query %>"><% } %>
      <% if (activeCategory) { %><input type="hidden" name="category" value="<%= activeCategory %>"><% } %>
      <label class="sort-label" for="sort">Sortieren</label>
      <select id="sort" name="sort" data-sort-select>
        <option value="" <%= !sort ? 'selected' : '' %>>Neueste</option>
        <option value="preis-auf" <%= sort === 'preis-auf' ? 'selected' : '' %>>Preis aufsteigend</option>
        <option value="preis-ab" <%= sort === 'preis-ab' ? 'selected' : '' %>>Preis absteigend</option>
        <option value="name" <%= sort === 'name' ? 'selected' : '' %>>Name (A–Z)</option>
      </select>
    </form>
  </div>

  <% if (items.length) { %>
    <div class="product-grid">
      <% items.forEach((p) => { %>
        <%- include('../partials/product-card', { p }) %>
      <% }) %>
    </div>

    <% if (totalPages > 1) { %>
      <nav class="pagination" aria-label="Seiten">
        <% for (let i = 1; i <= totalPages; i++) {
          let qs = '';
          if (query) qs += 'q=' + encodeURIComponent(query) + '&';
          if (activeCategory) qs += 'category=' + encodeURIComponent(activeCategory) + '&';
          if (sort) qs += 'sort=' + encodeURIComponent(sort) + '&';
          qs += 'page=' + i;
        %>
          <a class="page <%= i === page ? 'active' : '' %>" href="<%- basePath %>/shop?<%= qs %>"><%= i %></a>
        <% } %>
      </nav>
    <% } %>
  <% } else { %>
    <p class="muted">Keine Produkte in dieser Kategorie.</p>
  <% } %>
</main>

<%- include('../partials/site-footer') %>
